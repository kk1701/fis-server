generator client {
  provider     = "prisma-client-js"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int           @id @default(autoincrement())
  email        String        @unique
  passwordHash String
  role         UserRole
  status       AccountStatus @default(PENDING)
  createdAt    DateTime      @default(now())
  approvedAt   DateTime?
  deletedAt DateTime?
  approvedById Int?
  faculty      Faculty?
  approvedBy   User?         @relation("AdminApproval", fields: [approvedById], references: [id])
  approvals    User[]        @relation("AdminApproval")
}

model Faculty {
  id            Int                       @id @default(autoincrement())
  name          String
  dob           DateTime?
  gender        Gender?
  nationality   String?
  category      String?
  mobile        String?
  orcidId       String?                   @unique
  userId        Int                       @unique
  departmentId  Int
  createdAt     DateTime                  @default(now())
  addresses     Address[]
  coursesTaught Courses[]
  degrees       Degree[]
  dissertations DissertationSupervision[]
  employments   Employment[]
  experiences   Experience[]
  department    Department                @relation(fields: [departmentId], references: [id])
  user          User                      @relation(fields: [userId], references: [id])
  laboratories  Laboratory[]
  publications  Publication[]
  theses        ThesisSupervision[]
  designation          String?
  specialization       String[]
  joiningDate          DateTime?
  highestQualification String?
  experienceYears      Int?
  photoUrl             String?
}

model Department {
  id      Int       @id @default(autoincrement())
  name    String    @unique
  code    String    @unique  
  faculty Faculty[]
  courses Courses[]
  courseCatalog  CourseCatalog[]
}

model Address {
  id        Int         @id @default(autoincrement())
  type      AddressType
  line1     String
  line2     String?
  line3     String?
  district  String
  state     String
  country   String
  pin       String
  facultyId Int
  faculty   Faculty     @relation(fields: [facultyId], references: [id])

  @@unique([facultyId, type])
}

model Employment {
  id               Int       @id @default(autoincrement())
  organization     String
  designation      String
  natureOfWork     String
  payLevel         String?
  organizationType String
  startDate        DateTime
  endDate          DateTime?
  facultyId        Int
  faculty          Faculty   @relation(fields: [facultyId], references: [id])
}

model Degree {
  id             Int     @id @default(autoincrement())
  degreeName     String
  level          DegreeLevel
  specialization String
  institute      String
  yearOfPassing  Int
  score          Float?
  scoreType      String?
  division       String?
  facultyId      Int
  faculty        Faculty @relation(fields: [facultyId], references: [id])
}

model Experience {
  id           Int            @id @default(autoincrement())
  type         ExperienceType
  organization String
  designation  String
  natureOfWork String
  payScale     String?
  startDate    DateTime
  endDate      DateTime?
  facultyId    Int
  location     String?
  faculty      Faculty        @relation(fields: [facultyId], references: [id])
}

model CourseCatalog {
  id           Int         @id @default(autoincrement())
  name         String
  code         String      @unique
  departmentId Int
  level        CourseLevel
  credits      Int?
  department   Department  @relation(fields: [departmentId], references: [id])
  coursesTaught Courses[]
}

model Courses {
  id              Int          @id @default(autoincrement())
  catalogCourseId Int
  semester        String
  academicYear    String
  role            String 
  hoursPerWeek    Int?
  mode            String? 
  notes           String?
  facultyId       Int
  departmentId    Int
  createdAt       DateTime     @default(now())
  faculty         Faculty      @relation(fields: [facultyId], references: [id])
  department      Department   @relation(fields: [departmentId], references: [id])
  catalogCourse   CourseCatalog @relation(fields: [catalogCourseId], references: [id])
}

model Laboratory {
  id        Int         @id @default(autoincrement())
  name      String
  level     CourseLevel
  branch    String
  facultyId Int
  faculty   Faculty     @relation(fields: [facultyId], references: [id])
}

model Publication {
  id        Int                 @id @default(autoincrement())
  title     String
  category  PublicationCategory
  publisher String
  isbn      String?
  year      Int
  indexing  PublicationIndexing
  edition   String?
  facultyId Int
  authors  String[]
  doi      String?
  url      String?
  citation String?
  venue    String?
  pages    String?
  faculty   Faculty             @relation(fields: [facultyId], references: [id])
}

model ThesisSupervision {
  id           Int     @id @default(autoincrement())
  title        String
  researchArea String
  year         Int
  status       String
  role         String
  facultyId    Int
  faculty      Faculty @relation(fields: [facultyId], references: [id])
}

model DissertationSupervision {
  id             Int     @id @default(autoincrement())
  title          String
  specialization String
  year           Int
  role           String
  facultyId      Int
  faculty        Faculty @relation(fields: [facultyId], references: [id])
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum AddressType {
  CORRESPONDENCE
  PERMANENT
}

enum ExperienceType {
  TEACHING
  INDUSTRIAL
  RESEARCH
  ADMINISTRATIVE
}

enum PublicationCategory {
  JOURNAL
  CONFERENCE
  BOOK
  BOOK_CHAPTER
}

enum PublicationIndexing {
  SCI
  SCOPUS
  NONE
}

enum CourseLevel {
  UG
  PG
  PHD
}

enum UserRole {
  ADMIN
  FACULTY
}

enum AccountStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum DegreeLevel {
  TENTH
  TWELFTH
  DIPLOMA
  GRADUATION
  POST_GRADUATION
  DOCTORATE
  OTHER
}